#!/bin/sh
# Pre-commit: auto-format staged Swift files with SwiftFormat, then lint with SwiftLint.
# Install once per clone: run `make setup`

set -e

STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep '\.swift$' || true)
[ -z "$STAGED" ] && exit 0

# SwiftFormat — auto-fix formatting and re-stage
if command -v swiftformat > /dev/null 2>&1; then
    printf '%s\n' $STAGED | xargs swiftformat --quiet
    printf '%s\n' $STAGED | xargs git add
else
    echo "warning: swiftformat not found — skipping (brew install swiftformat)"
fi

# SwiftLint — fail commit on errors
if command -v swiftlint > /dev/null 2>&1; then
    printf '%s\n' $STAGED | xargs swiftlint lint --reporter emoji
else
    echo "warning: swiftlint not found — skipping (brew install swiftlint)"
fi
